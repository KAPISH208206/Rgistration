# Copy this file to .env.local for local development.
# On Vercel, set REACT_APP_API_URL as an Environment Variable in the
# project dashboard instead (Settings -> Environment Variables).
#
# IMPORTANT: This must include /api at the end, and must NOT have a
# trailing slash after that, since the code does `${REACT_APP_API_URL}/events` etc.

# Local dev (your backend running on your machine):
REACT_APP_API_URL=http://localhost:5000/api

# Production example (your deployed Render backend):
# REACT_APP_API_URL=https://your-backend.onrender.com/api
