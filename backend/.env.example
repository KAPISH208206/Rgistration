# Copy this file to .env for local development.
# On Render, set these as Environment Variables in the dashboard instead
# (do NOT upload a .env file to Render).

# Local dev default. Render sets PORT automatically — you don't need to set it there.
PORT=5000

# Local: mongodb://localhost:27017/event_registration
# Production: your MongoDB Atlas connection string, e.g.
# mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/event_registration?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/event_registration

# Use a long, random string in production
JWT_SECRET=your_jwt_secret_key_change_this

# Your deployed Vercel frontend URL (no trailing slash), e.g.
# https://your-app.vercel.app
# Used for CORS — required in production, optional for local dev.
FRONTEND_URL=http://localhost:3000
